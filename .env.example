# ==========================================
# 墨尼哲 API（故事、日历、历史上的今天）
# 申请地址：https://www.mxnzp.com/
# ==========================================
MXNZP_APP_ID=your_app_id_here
MXNZP_APP_SECRET=your_app_secret_here

# ==========================================
# Created by Vercel CLI[用于GitHub Action]
# 获取 Vercel Token
# 1. 访问 vercel.com/account/tokens (https://vercel.com/account/tokens)
# 2. 点击 Create
# 3. 输入 Token 名称（如 github-actions）
# 4. 点击 Generate
# 5. 复制生成的 Token
# 申请地址：https://vercel.com/account/tokens
# ==========================================

VERCEL_TOKEN=your_vercel_oidc_token_here


# ==========================================
# 智谱 AI API Key（用于 AI 功能）
# 申请地址：https://open.bigmodel.cn/
# ==========================================
# ZHIPU_API_KEY=your_zhipu_api_key_here

# ==========================================
# Gemini API Key（用于颜色分析等功能）
# 申请地址：https://aistudio.google.com/app/apikey
# ==========================================
# GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# 代理配置（可选，如有需要）
# ==========================================
# PROXY=http://127.0.0.1:7890